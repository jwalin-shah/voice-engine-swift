#!/bin/bash
# Build VoiceEngine release and install the binary to ~/local/bin/voice-engine.
# This is the simple path: no .app bundle, no Accessibility permission needed.
set -euo pipefail

DIR="$(cd "$(dirname "$0")/.." && pwd)"
BIN_DIR="$HOME/local/bin"
INSTALL_BIN="$BIN_DIR/voice-engine"
ENTITLEMENTS="$DIR/VoiceEngine.entitlements"

cd "$DIR"

echo "==> Building release..."
swift build -c release --package-path "$DIR"

echo "==> Installing to $INSTALL_BIN..."
mkdir -p "$BIN_DIR"
cp -f "$DIR/.build/release/voice-engine" "$INSTALL_BIN"

echo "==> Code-signing (ad-hoc)..."
codesign --force --sign - \
    --entitlements "$ENTITLEMENTS" \
    --options runtime \
    "$INSTALL_BIN" 2>/dev/null || true

echo "==> Done."
echo ""
echo "Start it with:"
echo "  ./bin/run"
echo ""
echo "Or manually:"
echo "  nohup ~/local/bin/voice-engine > /dev/null 2>&1 &"
